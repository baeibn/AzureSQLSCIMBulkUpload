{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "parameters": {
    "workflowName": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },

    "sqlServerName": {
      "type": "string"
    },
    "sqlDatabaseName": {
      "type": "string"
    },
    "sqlTableName": {
      "type": "string"
    },

    "scimApiUri": {
      "type": "string"
    }
  },

  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "sqldw",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "Azure SQL",
        "api": {
          "id": "[concat(subscription().id, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/sqldw')]"
        }
      }
    },

    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('workflowName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', 'sqldw')]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",

          "parameters": {
            "SCIM_API_uri": {
              "type": "string",
              "defaultValue": "[parameters('scimApiUri')]"
            },
            "SQL_Servername": {
              "type": "string",
              "defaultValue": "[parameters('sqlServerName')]"
            },
            "Database": {
              "type": "string",
              "defaultValue": "[parameters('sqlDatabaseName')]"
            },
            "Tablename": {
              "type": "string",
              "defaultValue": "[parameters('sqlTableName')]"
            },
            "$connections": {
              "type": "object",
              "defaultValue": {
                "sqldw": {
                  "connectionId": "[resourceId('Microsoft.Web/connections', 'sqldw')]",
                  "connectionName": "sqldw",
                  "id": "[concat(subscription().id, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/sqldw')]"
                }
              }
            }
          },

          "triggers": {
            "Recurrence": {
              "type": "Recurrence",
              "recurrence": {
                "frequency": "Day",
                "interval": 5
              }
            }
          },

          "actions": {
            "Get_rows_(V2)": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['sqldw']['connectionId']"
                  }
                },
                "method": "get",
                "path": "/v2/datasets/@{encodeURIComponent(parameters('SQL_Servername'))},@{encodeURIComponent(parameters('Database'))}/tables/@{encodeURIComponent(parameters('Tablename'))}/items"
              }
            }
          },

          "outputs": {}
        }
      }
    }
  ]
}
